# =============================================================================
# LEXCC — .env.example (commit this file, never commit .env or .env.local)
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# FRONTEND — Vite / React (all values exposed to browser, VITE_ prefix required)
# These are the ONLY values Vite bundles into your frontend JS.
# -----------------------------------------------------------------------------

# Supabase Project URL — public, safe for browser
# Found: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://wptcntssrgsjrliwlprw.supabase.co

# Supabase anon/public key — governed by RLS, safe for browser
# Found: Supabase Dashboard → Settings → API → Project API Keys → anon / public
VITE_SUPABASE_ANON_KEY=

# Stripe Publishable Key — NOT YET CONFIGURED (add when you create your Stripe account)
# Found: Stripe Dashboard → Developers → API Keys → Publishable key
VITE_STRIPE_PUBLIC_KEY=

# Cloudflare Turnstile Site Key — NOT YET CONFIGURED (add when you create your Turnstile widget)
# Found: Cloudflare Dashboard → Turnstile → your site → Site Key
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=


# -----------------------------------------------------------------------------
# BACKEND — Supabase Edge Functions only (NEVER put these in frontend)
# Set via CLI: supabase secrets set KEY=value
# Listed here for documentation purposes only — do NOT set these as VITE_ vars.
# -----------------------------------------------------------------------------

# Stripe Secret Key — BACKEND ONLY
# STRIPE_SECRET_KEY=sk_live_...

# Stripe Webhook Signing Secret — BACKEND ONLY
# STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase Service Role Key — BACKEND ONLY (bypasses all RLS)
# Found: Supabase Dashboard → Settings → API → Project API Keys → service_role
# SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile Secret Key — BACKEND ONLY
# TURNSTILE_SECRET_KEY=

# Note: SUPABASE_URL is auto-injected into edge functions by the Supabase platform.
# You do NOT need to set it manually via supabase secrets set.
